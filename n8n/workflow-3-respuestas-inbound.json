        [{ "node": "Twilio: Responder Reagendar", "type": "main", "index": 0 }]
      ]
    },
    "Supabase: Confirmar Turno": {
      "main": [[{ "node": "Responder Twilio OK", "type": "main", "index": 0 }]]
